{
  "name": "truedesire",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/vite-wrapper.mjs",
    "build": "tsc -b && node scripts/vite-wrapper.mjs build",
    "typecheck": "tsc -b",
    "server:build": "tsc -p server/tsconfig.json",
    "server:start": "node server/dist/server.js",
    "lint": "eslint .",
    "preview": "node scripts/vite-wrapper.mjs preview",
    "test:e2e": "playwright test",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "docker:prod:build": "docker build -f Dockerfile.prod -t beberhardt/truedesire:local .",
    "test:e2e:docker": "docker compose -f docker-compose.e2e.yml up --build --abort-on-container-exit --exit-code-from playwright-e2e playwright-e2e",
    "test:e2e:docker:ui": "docker compose -f docker-compose.e2e.yml --profile ui up --build playwright-e2e-ui"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.1.4"
  }
}
