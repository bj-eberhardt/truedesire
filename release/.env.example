TRUEDESIRE_TAG=latest
PORT=3001
PUBLISHED_PORT=3001
LOG_LEVEL=info
REQUEST_LOGS=true

WEEKLY_LIMIT_DEFAULT=15
SYSTEM_QUESTIONS_FILE=/app/server/default-data/system-questions.json
POSTGRES_USER=truedesire
POSTGRES_PASSWORD=change-me
POSTGRES_DB=truedesire
DB_SSL=false
DB_MIGRATIONS_LOCK_TIMEOUT_MS=10000

PAIRING_LIMIT_USER_PER_MIN=10
PAIRING_LIMIT_USER_PER_HOUR=50
PAIRING_LIMIT_IP_PER_MIN=30
PAIRING_LIMIT_IP_PER_HOUR=200

# Optional. Leave empty in same-origin Docker production.
VITE_API_BASE=
